# Test suite isn't needed to run the server. Keeps image ~500KB slimmer.
tests/
conftest.py

# Docs / editor metadata
docs/
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Deploy configs shouldn't ship inside the image
deploy/
docker-compose.yml
Dockerfile
.dockerignore
