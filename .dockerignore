# Version control / worktrees
.git
.git/
.gitignore
.github/
.claude/

# Python build + cache
.venv/
venv/
env/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/
.ruff_cache/
