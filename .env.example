# Copy this file to .env and fill in your own values.
# Get credentials at https://dashboard.plaid.com/developers/keys

PLAID_CLIENT_ID=
PLAID_SECRET=

# sandbox (fake data) | production (real banks, limited items on free trial).
# Plaid retired the "development" environment in late 2024; new accounts only
# get Sandbox and a limited Production trial (~10 items). If your config still
# says `development` we silently route it to Production.
PLAID_ENV=production

# Products the bank MUST support at link time. If the bank doesn't have
# every product in this list, Plaid will refuse to link it.
PLAID_PRODUCTS=transactions

# Products to request if the bank supports them, without failing the link
# if it doesn't. Lets one config work across checking banks, brokerages,
# and credit card issuers. Only include products you're approved for.
PLAID_OPTIONAL_PRODUCTS=investments,liabilities,identity

# Comma-separated ISO country codes (US,CA,GB,ES,FR,IE,NL,DE,IT)
PLAID_COUNTRY_CODES=US

# Where to store access tokens + cached transaction data.
# Tilde (~) is expanded. File will be chmod 600.
PLAID_MCP_DB=~/.plaid-mcp/plaid.db

# Display name shown in Plaid Link
PLAID_CLIENT_NAME=plaid-mcp

# Optional: bearer token required for remote HTTP mode.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MCP_AUTH_TOKEN=

# Optional: webhook URL if you deploy remotely and want live transaction updates.
# PLAID_WEBHOOK_URL=https://your-host.example.com/webhook

# ---------- Provider selection & Teller ----------
#
# Which bank-data source to use. plaid = default, teller = simpler/cheaper
# but no investments/liabilities.
PROVIDER=plaid

# Teller settings (only needed when PROVIDER=teller).
# Application ID from https://dashboard.teller.io (not secret — used by Connect widget).
# TELLER_APPLICATION_ID=app_xxxxxxxxxxxxxxxxxxxxxx
# TELLER_ENV=sandbox           # sandbox | development | production
# TELLER_CERT_PATH=~/.plaid-mcp/teller/certificate.pem
# TELLER_KEY_PATH=~/.plaid-mcp/teller/private_key.pem

# ---------- Payments (paid hosting, opt-in) ----------
#
# Off by default — stdio users and self-hosted HTTP users pay nothing.
# Set PAYWALL=x402 only when running plaid-mcp as a hosted service and
# you want to meter per-tool calls over USDC on Base. Tool discovery
# (tools/list, initialize) stays free regardless.
# PAYWALL=none                              # none | x402
# X402_RECEIVING_ADDRESS=0x...              # Base address that receives USDC
# X402_NETWORK=base-sepolia                 # base-sepolia (testnet) | base (mainnet)
# X402_FACILITATOR_URL=                     # optional override
